  "attack_configs": [
    {
      "attack_type": "packet_loss",
      "epsilon": 0.01,
      "evaluation_episodes": 100
    },
    {
      "attack_type": "packet_loss", 
      "epsilon": 0.05,
      "evaluation_episodes": 100
    },
    {
      "attack_type": "packet_loss",
      "epsilon": 0.1,
      "evaluation_episodes": 100
    },
    {
      "attack_type": "packet_loss",
      "epsilon": 0.15,
      "evaluation_episodes": 100
    },
    {
      "attack_type": "packet_loss",
