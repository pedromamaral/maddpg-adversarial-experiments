{
  "experiment_name": "MADDPG_Adversarial_Robustness_Study",
  "description": "Comprehensive evaluation of MADDPG variants under FGSM attacks",
  
  "topology": {
    "type": "service_provider",
    "nodes": 65,
    "max_links": 4
