{
  "experiment_name": "MADDPG_Hop_By_Hop_Routing",
  "description": "Hop-by-hop MADDPG variants \u2014 architecture comparison (Paper 1) and adversarial attack study (Paper 2)",
  "topology": {
    "type": "service_provider_real",
    "nodes": 86,
    "max_links": 11
  },
  "training": {
    "epochs": 400,
    "episodes_per_epoch": 5,
    "timesteps_per_episode": 256,
    "batch_size": 512,
    "memory_size": 100000,
    "learn_freq": 10,
    "trainable_host_filter": "dist_nodes",
    "exploration": {
      "enabled": true,
      "epsilon_start": 1.0,
      "epsilon_end": 0.05,
      "epsilon_decay_epochs": 50,
      "decision_block_size": 3,
      "mode": "epsilon_greedy"
    },
    "gamma": 0.95,
    "tau": 0.005,
    "parallel_workers": 0,
    "freeze_single_link_nodes": true,
    "learn_action_projection": {
      "critic_target_mode": "block_argmax_onehot",
      "actor_mode": "st_onehot"
    },
    "best_checkpoint": {
      "enabled": true,
      "metric": "mean_reward",
      "validation_interval_epochs": 10,
      "validation_episodes": 5,
      "min_improvement": 0.001,
      "warmup_epochs": 60
    },
    "early_stopping": {
      "enabled": true,
      "metric": "mean_reward",
      "patience_checks": 12,
      "smooth_window_checks": 3,
      "min_epochs": 80
    },
    "offered_load_factor": 1.00
  },
  "traffic": {
    "mode": "flow",
    "packet_size": 0.03,
    "flow_packet_size": 0.03,
    "flow_hold_steps": 8,
    "flow_duration_steps": 12,
    "flow_count": 21,
    "episode_steps": 256
  },
  "paper1_eval": {
    "evaluation_episodes": 30,
    "link_failure_scenarios": [
      0,
      2
    ]
  },
  "load_sweep": {
    "enabled": true,
    "offered_loads": [
      0.4,
      0.6,
      0.8,
      1.0,
      1.1,
      1.2,
      1.3,
      1.5,
      1.8,
      2.0,
      2.5,
      3.0
    ],
    "include_failures": false
  },
  "clean_slo": {
    "max_pkt_loss_pct": 5.0,
    "max_delay_p95": 15.0,
    "min_end_to_end_pdr_pct": 85.0
  },
  "reward": {
    "_comment": "All variants now use the same shared flow reward: delivery_weight * delivery_rate - drop_penalty * packet_loss - mean_util_weight * mean_util - var_util_penalty * util_variance - backlog_penalty * backlog. LC and CC differ only in critic/encoder architecture, not objective.",
    "delivery_weight": 1.0,
    "drop_penalty": 1.0,
    "mean_util_weight": 0.8,
    "progress_shaping_weight": 0.0,
    "max_util_penalty": 0.0,
    "congestion_threshold": 0.8,
    "var_util_penalty": 0.3,
    "backlog_penalty": 0.0,
    "path_alpha": 0.7
  },
  "runtime_control": {
    "profile": "standard",
    "max_attack_cases_per_variant": -1,
    "max_attack_variants": -1,
    "phase3_enable_slo_pruning": false,
    "phase3_consecutive_fail_limit": 2,
    "phase3_skip_after_critical_epsilon": false,
    "seed_expansion": {
      "enable_adaptive": true,
      "initial_seeds": 10,
      "max_seeds_for_ranking": 50,
      "rank_stability_check_interval": 5,
      "top_k_for_stability": 5,
      "stability_threshold": 0.95
    },
    "profiles": {
      "standard": {},
      "thorough": {},
      "quick": {
        "training": {
          "epochs": 1,
          "episodes_per_epoch": 1,
          "timesteps_per_episode": 10
        },
        "paper1_eval": {
          "evaluation_episodes": 2
        },
        "attack_eval_episodes": 2
      }
    }
  },
  "variants": [
    {
      "_comment": "CC critic dims dynamically computed as actor_dims*n_trainable_agents = 37*32 = 1184 (state) + 32*63 = 2016 (action) = 3200 FC1 input; fc1/fc2 sized for this reduced footprint.",
      "name": "CC-Simple",
      "critic_domain": "central_critic",
      "neural_network": "simple_q_network",
      "use_gnn": false,
      "actor_dims": 37,
      "critic_dims": 1184,
      "n_agents": 32,
      "n_actions": 63,
      "fc1": 256,
      "fc2": 128,
      "alpha": 0.0003,
      "beta": 0.0003
    },
    {
      "name": "CC-Duelling",
      "critic_domain": "central_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": false,
      "actor_dims": 37,
      "critic_dims": 1184,
      "n_agents": 32,
      "n_actions": 63,
      "fc1": 256,
      "fc2": 128,
      "alpha": 0.0003,
      "beta": 0.0003
    },
    {
      "_comment": "Local critic uses only local state (actor_dims=37); independent of n_trainable_agents count.",
      "name": "LC-Duelling",
      "critic_domain": "local_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": false,
      "actor_dims": 37,
      "critic_dims": 37,
      "n_agents": 32,
      "n_actions": 63,
      "fc1": 256,
      "fc2": 128,
      "alpha": 0.0003,
      "beta": 0.0003
    },
    {
      "_comment": "GNN pre-processes all agents' observations via GraphConv before actor/critic; adjacency built from trainable subgraph at runtime.",
      "name": "CC-Simple-GNN",
      "critic_domain": "central_critic",
      "neural_network": "simple_q_network",
      "use_gnn": true,
      "actor_dims": 37,
      "critic_dims": 1184,
      "n_agents": 32,
      "n_actions": 63,
      "fc1": 256,
      "fc2": 128,
      "alpha": 0.0003,
      "beta": 0.0003
    },
    {
      "name": "CC-Duelling-GNN",
      "critic_domain": "central_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": true,
      "actor_dims": 37,
      "critic_dims": 1184,
      "n_agents": 32,
      "n_actions": 63,
      "fc1": 256,
      "fc2": 128,
      "alpha": 0.0003,
      "beta": 0.0003
    },
    {
      "name": "LC-Duelling-GNN",
      "critic_domain": "local_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": true,
      "actor_dims": 37,
      "critic_dims": 37,
      "n_agents": 32,
      "n_actions": 63,
      "fc1": 256,
      "fc2": 128,
      "alpha": 0.0003,
      "beta": 0.0003
    },
    {
      "_comment": "LC baseline: local critic with simple Q-network (no duelling). Establishes that LC > CC independent of network architecture.",
      "name": "LC-Simple",
      "critic_domain": "local_critic",
      "neural_network": "simple_q_network",
      "use_gnn": false,
      "actor_dims": 37,
      "critic_dims": 37,
      "n_agents": 32,
      "n_actions": 63,
      "fc1": 256,
      "fc2": 128,
      "alpha": 0.0003,
      "beta": 0.0003
    }
  ],
  "attack_configs": [
    {
      "attack_type": "packet_loss",
      "epsilon": 0.05,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "packet_loss",
      "epsilon": 0.1,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "packet_loss",
      "epsilon": 0.15,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "packet_loss",
      "epsilon": 0.2,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "reward_minimize",
      "epsilon": 0.05,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "reward_minimize",
      "epsilon": 0.1,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "reward_minimize",
      "epsilon": 0.15,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "reward_minimize",
      "epsilon": 0.2,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "confusion",
      "epsilon": 0.05,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "confusion",
      "epsilon": 0.1,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "confusion",
      "epsilon": 0.15,
      "evaluation_episodes": 50
    },
    {
      "attack_type": "confusion",
      "epsilon": 0.2,
      "evaluation_episodes": 50
    }
  ],
  "fgsm_slo": {
    "max_pkt_loss_pct": 12.0,
    "min_delivery_rate_pct": 30.0,
    "max_reward_degradation_pct": 25.0,
    "max_delay_p95": 18.0
  },
  "scoring": {
    "profiles": {
      "default": {
        "higher_is_better": {
          "mean_end_to_end_pdr": 0.35,
          "mean_goodput_per_step": 0.2
        },
        "lower_is_better": {
          "mean_pkt_loss": 0.2,
          "mean_delay_p95": 0.1,
          "mean_backlog_end": 0.05,
          "mean_hops_mean": 0.05,
          "mean_overload_fraction": 0.05
        }
      },
      "robustness": {
        "higher_is_better": {
          "mean_end_to_end_pdr": 0.25,
          "mean_goodput_per_step": 0.15
        },
        "lower_is_better": {
          "mean_pkt_loss": 0.3,
          "mean_delay_p95": 0.1,
          "mean_backlog_end": 0.05,
          "mean_hops_mean": 0.1,
          "mean_overload_fraction": 0.05
        }
      }
    }
  },
  "hardware": {
    "gpu_memory_gb": 16,
    "use_mixed_precision": true,
    "parallel_episodes": 4
  },
  "output": {
    "save_models": true,
    "save_intermediate_results": true,
    "generate_plots": true,
    "plot_format": "png",
    "plot_dpi": 300
  }
}
