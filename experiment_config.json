      "actor_dims": [26],
      "critic_dims": [91],
      "n_agents": 65,
      "n_actions": 3
    },
    {
      "name": "CC-Duelling",
      "critic_domain": "central_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": false,
      "actor_dims": [26],
      "critic_dims": [91], 
      "n_agents": 65,
      "n_actions": 3
    },
    {
      "name": "LC-Duelling", 
      "critic_domain": "local_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": false,
      "actor_dims": [26],
      "critic_dims": [26],
      "n_agents": 65,
      "n_actions": 3
    },
    {
      "name": "CC-Simple-GNN",
      "critic_domain": "central_critic",
      "neural_network": "simple_q_network",
      "use_gnn": true,
      "actor_dims": [26],
      "critic_dims": [91],
      "n_agents": 65,
      "n_actions": 3
    },
    {
      "name": "CC-Duelling-GNN",
      "critic_domain": "central_critic", 
