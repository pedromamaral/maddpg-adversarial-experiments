{
  "experiment_name": "MADDPG_Hop_By_Hop_Routing",
  "description": "Hop-by-hop MADDPG variants — architecture comparison (Paper 1) and adversarial attack study (Paper 2)",

  "topology": {
    "type": "service_provider",
    "nodes": 65,
    "max_links": 11
  },

  "training": {
    "epochs": 400,
    "episodes_per_epoch": 5,
    "timesteps_per_episode": 256,
    "batch_size": 256,
    "memory_size": 50000,
    "exploration": {
      "enabled": true,
      "epsilon_start": 0.30,
      "epsilon_end": 0.02,
      "epsilon_decay_epochs": 300,
      "decision_block_size": 3,
      "mode": "epsilon_greedy"
    },
    "parallel_workers": 0,
    "freeze_single_link_nodes": true,
    "learn_action_projection": {
      "critic_target_mode": "block_argmax_onehot",
      "actor_mode": "st_onehot"
    },
    "best_checkpoint": {
      "enabled": true,
      "metric": "mean_pkt_loss",
      "validation_interval_epochs": 20,
      "validation_episodes": 5,
      "min_improvement": 0.001,
      "warmup_epochs": 40
    },
    "early_stopping": {
      "enabled": true,
      "metric": "mean_pkt_loss",
      "patience_checks": 8,
      "smooth_window_checks": 3,
      "min_epochs": 120
    }
  },

  "paper1_eval": {
    "evaluation_episodes": 30,
    "link_failure_scenarios": [0, 2]
  },

  "load_sweep": {
    "enabled": true,
    "offered_loads": [0.75, 1.0, 1.25, 1.5],
    "include_failures": false
  },

  "clean_slo": {
    "max_pkt_loss_pct": 5.0,
    "max_delay_p95": 8.0,
    "min_end_to_end_pdr_pct": 85.0
  },

  "reward": {
    "delivery_weight": 1.0,
    "max_util_penalty": 2.0,
    "congestion_threshold": 0.7,
    "var_util_penalty": 0.4,
    "drop_penalty": 0.6,
    "backlog_penalty": 0.05,
    "progress_shaping_weight": 0.4
  },

  "runtime_control": {
    "profile": "standard",
    "max_attack_cases_per_variant": -1,
    "max_attack_variants": -1,
    "phase3_enable_slo_pruning": true,
    "phase3_consecutive_fail_limit": 2,
    "phase3_skip_after_critical_epsilon": true,
    "seed_expansion": {
      "enable_adaptive": true,
      "initial_seeds": 10,
      "max_seeds_for_ranking": 50,
      "rank_stability_check_interval": 5,
      "top_k_for_stability": 5,
      "stability_threshold": 0.95
    },
    "profiles": {
      "standard": {},
      "thorough": {},
      "quick": {
        "training": {
          "epochs": 1,
          "episodes_per_epoch": 1,
          "timesteps_per_episode": 10
        },
        "paper1_eval": {
          "evaluation_episodes": 2
        },
        "attack_eval_episodes": 2
      }
    }
  },

  "variants": [
    {
      "name": "CC-Simple",
      "critic_domain": "central_critic",
      "neural_network": "simple_q_network",
      "use_gnn": false,
      "actor_dims": 61, "critic_dims": 3965,
      "n_agents": 65, "n_actions": 120,
      "fc1": 512, "fc2": 128,
      "alpha": 0.001, "beta": 0.001
    },
    {
      "name": "CC-Duelling",
      "critic_domain": "central_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": false,
      "actor_dims": 61, "critic_dims": 3965,
      "n_agents": 65, "n_actions": 120,
      "fc1": 512, "fc2": 128,
      "alpha": 0.001, "beta": 0.001
    },
    {
      "name": "LC-Duelling",
      "critic_domain": "local_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": false,
      "actor_dims": 61, "critic_dims": 61,
      "n_agents": 65, "n_actions": 120,
      "alpha": 0.001, "beta": 0.001
    },
    {
      "name": "CC-Simple-GNN",
      "critic_domain": "central_critic",
      "neural_network": "simple_q_network",
      "use_gnn": true,
      "actor_dims": 61, "critic_dims": 3965,
      "n_agents": 65, "n_actions": 120,
      "fc1": 512, "fc2": 128,
      "alpha": 0.001, "beta": 0.001
    },
    {
      "name": "CC-Duelling-GNN",
      "critic_domain": "central_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": true,
      "actor_dims": 61, "critic_dims": 3965,
      "n_agents": 65, "n_actions": 120,
      "fc1": 512, "fc2": 128,
      "alpha": 0.001, "beta": 0.001
    },
    {
      "name": "LC-Duelling-GNN",
      "critic_domain": "local_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": true,
      "actor_dims": 61, "critic_dims": 61,
      "n_agents": 65, "n_actions": 120,
      "alpha": 0.001, "beta": 0.001
    },
    {
      "name": "NC-Simple",
      "critic_domain": "neighborhood_critic",
      "neural_network": "simple_q_network",
      "use_gnn": false,
      "actor_dims": 61, "critic_dims": 0,
      "n_agents": 65, "n_actions": 120,
      "fc1": 256, "fc2": 128,
      "alpha": 0.001, "beta": 0.001
    },
    {
      "name": "NC-Duelling",
      "critic_domain": "neighborhood_critic",
      "neural_network": "duelling_q_network",
      "use_gnn": false,
      "actor_dims": 61, "critic_dims": 0,
      "n_agents": 65, "n_actions": 120,
      "fc1": 256, "fc2": 128,
      "alpha": 0.001, "beta": 0.001
    }
  ],

  "attack_configs": [
    {"attack_type": "packet_loss",     "epsilon": 0.01, "evaluation_episodes": 30},
    {"attack_type": "packet_loss",     "epsilon": 0.05, "evaluation_episodes": 30},
    {"attack_type": "packet_loss",     "epsilon": 0.10, "evaluation_episodes": 30},
    {"attack_type": "packet_loss",     "epsilon": 0.15, "evaluation_episodes": 30},
    {"attack_type": "packet_loss",     "epsilon": 0.20, "evaluation_episodes": 30},
    {"attack_type": "reward_minimize", "epsilon": 0.05, "evaluation_episodes": 30},
    {"attack_type": "confusion",       "epsilon": 0.05, "evaluation_episodes": 30}
  ],

  "fgsm_slo": {
    "max_pkt_loss_pct": 10.0,
    "min_delivery_rate_pct": 20.0,
    "max_reward_degradation_pct": 25.0,
    "max_delay_p95": 12.0
  },

  "scoring": {
    "profiles": {
      "default": {
        "higher_is_better": {
          "mean_end_to_end_pdr": 0.35,
          "mean_goodput_per_step": 0.20
        },
        "lower_is_better": {
          "mean_pkt_loss": 0.20,
          "mean_delay_p95": 0.10,
          "mean_backlog_end": 0.05,
          "mean_hops_mean": 0.05,
          "mean_overload_fraction": 0.05
        }
      },
      "robustness": {
        "higher_is_better": {
          "mean_end_to_end_pdr": 0.25,
          "mean_goodput_per_step": 0.15
        },
        "lower_is_better": {
          "mean_pkt_loss": 0.30,
          "mean_delay_p95": 0.10,
          "mean_backlog_end": 0.05,
          "mean_hops_mean": 0.10,
          "mean_overload_fraction": 0.05
        }
      }
    }
  },

  "hardware": {
    "gpu_memory_gb": 16,
    "use_mixed_precision": true,
    "parallel_episodes": 4
  },

  "output": {
    "save_models": true,
    "save_intermediate_results": true,
    "generate_plots": true,
    "plot_format": "png",
    "plot_dpi": 300
  }
}