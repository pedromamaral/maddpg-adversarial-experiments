      "use_gnn": true,
      "actor_dims": [26],
      "critic_dims": [91],
      "n_agents": 65,
      "n_actions": 3
    },
    {
      "name": "LC-Duelling-GNN",
      "critic_domain": "local_critic",
      "neural_network": "duelling_q_network", 
      "use_gnn": true,
      "actor_dims": [26],
      "critic_dims": [26],
      "n_agents": 65,
      "n_actions": 3
    }
